# This is the configuration file for Ghostty.
# Managed by chezmoi: see https://github.com/<user>/dotfiles
#
# Ghostty searches several paths for config on macOS, including:
#   - $XDG_CONFIG_HOME/ghostty/config  (this file, when XDG_CONFIG_HOME=$HOME/.config)
#   - ~/Library/Application Support/com.mitchellh.ghostty/config
#
# Reload while running: Command + Shift + comma (macOS default).
# Docs: https://ghostty.org/docs/config

font-family = "Osaka Mono"
font-family = "Noto Sans CJK KR"

# 어디서든(전역) quick terminal 토글
keybind = global:cmd+backquote=toggle_quick_terminal
quick-terminal-autohide = false

# split 포커스 이동 (생성 순서 기준)
keybind = cmd+up=goto_split:up
keybind = cmd+down=goto_split:down
keybind = cmd+left=goto_split:left
keybind = cmd+right=goto_split:right

# 재설정
keybind = cmd+shift+r=reload_config

# 어디서 내려오게 + 높이(화면 비율/픽셀 둘 다 가능)
quick-terminal-position = bottom
quick-terminal-size = 70%
# 1.0 = 불투명, 0.85 정도부터 살짝 반투명 느낌
background-opacity = 0.94

# 포커스 잃으면 자동으로 숨김(기본 true가 macOS)
quick-terminal-autohide = true
quick-terminal-screen = macos-menu-bar

macos-hidden = always

copy-on-select = clipboard
