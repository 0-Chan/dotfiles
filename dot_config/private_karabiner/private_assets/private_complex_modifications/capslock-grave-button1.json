{
  "title": "CapsLock + ` -> Left click (preserves CapsLock toggle on tap)",
  "rules": [
    {
      "description": "CapsLock + grave_accent_and_tilde -> button1 (left click)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": { "optional": ["any"] }
          },
          "to": [
            { "set_variable": { "name": "caps_lock_pressed", "value": 1 } }
          ],
          "to_after_key_up": [
            { "set_variable": { "name": "caps_lock_pressed", "value": 0 } }
          ],
          "to_if_alone": [
            { "key_code": "caps_lock", "hold_down_milliseconds": 100 }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            { "type": "variable_if", "name": "caps_lock_pressed", "value": 1 }
          ],
          "from": {
            "key_code": "grave_accent_and_tilde",
            "modifiers": { "optional": ["any"] }
          },
          "to": [
            { "pointing_button": "button1" }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            { "type": "input_source_if", "input_sources": [{ "language": "ko" }] }
          ],
          "from": {
            "key_code": "grave_accent_and_tilde",
            "modifiers": { "mandatory": ["left_option"], "optional": ["any"] }
          },
          "to": [
            { "pointing_button": "button1" }
          ]
        }
      ]
    }
  ]
}
