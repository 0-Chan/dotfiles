#!/bin/bash
set -euo pipefail

ZSH_DIR="${ZSH:-$HOME/.oh-my-zsh}"
ZSH_CUSTOM_DIR="${ZSH_CUSTOM:-$ZSH_DIR/custom}"

if ! command -v git >/dev/null; then
  echo "[omz] git이 설치되지 않아 건너뜀" >&2
  exit 0
fi

# ── oh-my-zsh 본체 ──
if [ ! -d "$ZSH_DIR" ]; then
  echo "[omz] oh-my-zsh 클론..."
  git clone --depth=1 https://github.com/ohmyzsh/ohmyzsh.git "$ZSH_DIR"
else
  echo "[omz] oh-my-zsh 이미 설치됨 — skip"
fi

# ── custom 외부 플러그인 (zsh-users 공식 소스) ──
CUSTOM_PLUGINS=(
  "zsh-autosuggestions|https://github.com/zsh-users/zsh-autosuggestions"
  "zsh-syntax-highlighting|https://github.com/zsh-users/zsh-syntax-highlighting.git"
)

for entry in "${CUSTOM_PLUGINS[@]}"; do
  name="${entry%%|*}"
  url="${entry##*|}"
  target="$ZSH_CUSTOM_DIR/plugins/$name"
  if [ ! -d "$target" ]; then
    echo "[omz] custom plugin $name 클론..."
    git clone --depth=1 "$url" "$target"
  else
    echo "[omz] custom plugin $name 이미 존재 — skip"
  fi
done
